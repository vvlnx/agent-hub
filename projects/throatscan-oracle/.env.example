# OpenAI Responses API (required for live, web-grounded industry inference)
OPENAI_API_KEY=sk-...

# Optional overrides
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4-mini

# Responses API hosted web search. Enabled by default when LLM augmentation runs.
# OPENAI_WEB_SEARCH=1
# OPENAI_SEARCH_CONTEXT_SIZE=medium

# Optional comma-separated domain filters (hostnames only, no https:// prefix).
# OPENAI_WEB_SEARCH_ALLOWED_DOMAINS=sec.gov,investor.example.com
# OPENAI_WEB_SEARCH_BLOCKED_DOMAINS=reddit.com,quora.com

# Enable constrained LLM augmentation. Without this flag, the deterministic
# reasoning engine is used even when OPENAI_API_KEY is configured.
# THROATSCAN_LLM=1

# Agent Hub news-briefing + macro-analyst runtime research.
# Enabled by default. Set to 0 only for offline development.
# THROATSCAN_MARKET_RESEARCH=1
# MARKET_DATA_MCP_URL=https://datahub.noxiaohao.com/mcp

# Optional public demo URL shown in /api/health (set after Vercel deploy)
# THROATSCAN_PUBLIC_DEMO_URL=https://throatscan-oracle.vercel.app

# Optional public GitHub repo URL for completeness pack
# THROATSCAN_GITHUB_REPO_URL=https://github.com/vvlnx/agent-hub

# Optional Bitget Demo Trading credentials (Tier 2 paper trading)
# Create a Demo API Key in Bitget → Personal Center → API Key Management (Demo mode)
# BITGET_DEMO_API_KEY=
# BITGET_DEMO_SECRET_KEY=
# BITGET_DEMO_PASSPHRASE=
#
# Alternative: reuse BITGET_API_KEY with demo keys and enable paper header explicitly
# BITGET_API_KEY=
# BITGET_SECRET_KEY=
# BITGET_PASSPHRASE=
# BITGET_PAPER_TRADING=1
